{
  "name": "apogee",
  "version": "0.5.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.18"
  },
  "description": "Apogee — a Liquid Network wallet for your browser.",
  "type": "module",
  "scripts": {
    "dev": "vite build --mode development --watch",
    "build": "vite build",
    "build:firefox": "node scripts/build-firefox.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "zip": "if ls .env .env.local .env.production .env.production.local 2>/dev/null | grep -q .; then echo 'refusing to zip: a .env file is present (credentials could ship in the bundle) — remove it or use the CI release zip' >&2; exit 1; fi && vite build && cd dist && zip -rX ../releases/apogee-$npm_package_version.zip ."
  },
  "dependencies": {
    "lucide-react": "^0.562.0",
    "lwk_wasm": "^0.18.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/chrome": "^0.1.43",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.0",
    "vite": "^7.3.5",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  }
}
